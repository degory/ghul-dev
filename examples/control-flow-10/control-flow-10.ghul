use IO.Std.write_line;

// >>>
union Result[T, E] is
    OK(value: T);
    ERR(error: E);
si
// <<<

some_call() -> Result[int, string] is
    return Result.OK[int, string](42);
si

entry() is
// >>>
    let r: Result[int, string] = some_call();

    if r.is_ok then
        write_line("ok: {r.value}");
    else
        // r is narrowed to Result.ERR here
        write_line("err: {r.error}");
    fi
// <<<
si
