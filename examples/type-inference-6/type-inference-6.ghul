use IO.Std.write_line;

class Animal() is
si

class Cat(): Animal is
    purr() -> string => "purr";
si

class CARRIER(occupant: Animal) is
si

// >>>
describe(carrier: CARRIER) is
    if let cat: Cat = carrier.occupant then
        write_line(cat.purr());
    fi
si
// <<<

entry() is
    describe(CARRIER(Cat()));
si
