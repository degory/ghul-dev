use IO.Std.write_line;

class Animal is
    init() is si
si

class Cat: Animal is
    init() is super.init(); si
    purr() -> string => "purr";
si

class CARRIER is
    occupant: Animal;

    init(occupant: Animal) is
        self.occupant = occupant;
    si
si

// >>>
describe(carrier: CARRIER) is
    if let cat: Cat = carrier.occupant then
        write_line(cat.purr());
    fi
si
// <<<

entry() is
    describe(CARRIER(Cat()));
si
