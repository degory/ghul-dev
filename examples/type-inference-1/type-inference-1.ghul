totals(
    values: Collections.Iterable[int]
) -> (sum: int, count: int) is
    let sum mut = 0;
    let count mut = 0;

    for v in values do
        sum = sum + v;
        count = count + 1;
    od

    return (sum, count);
si
// <<<

entry() is
    totals([1, 2, 3]);
