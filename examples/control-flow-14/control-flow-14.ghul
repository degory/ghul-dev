use IO.Std.write_line;

class Animal is si

class Cat(name: string): Animal is
    purr() -> string => "{name} purrs";
si

class Dog(name: string): Animal is
    bark() -> string => "{name} barks";
si

entry() is
    let a: Animal = Dog("rover");
// >>>
    if let c: Cat = a then
        write_line(c.purr());
    elif let d: Dog = a then
        write_line(d.bark());
    else
        write_line("some other animal");
    fi
// <<<
si
