use IO.Std.write_line;

fibs() -> Ghul.Pipes.Pipe[int] is
    let a mut = 0;
    let b mut = 1;
    do
        yield a;
        let next = a + b;
        a = b;
        b = next;
    od
si

entry() is
// >>>
    // fibs() is an infinite generator; take(8) bounds it
    for f in fibs() | .take(8) do
        write_line(f);
    od
// <<<
si
