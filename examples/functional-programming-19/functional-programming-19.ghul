use IO.Std.write_line;

entry() is
// >>>
    let curried_add = x => y => x + y;

    write_line("curried_add(5)(3): {curried_add(5)(3)}");

    let add_5 = curried_add(5);
    write_line("add_5(3): {add_5(3)}");

    let add_10 = curried_add(10);
    write_line("add_10(3): {add_10(3)}");
// <<<
si
