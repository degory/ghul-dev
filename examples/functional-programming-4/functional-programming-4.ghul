use IO.Std.write_line;

entry() is
// >>>
    let is_odd mut = default;

    let is_even = n =>
        if n == 0 then true else is_odd(n - 1) fi;

    is_odd = n =>
        if n == 0 then false else is_even(n - 1) fi;

    write_line("even(10): {is_even(10)}");
    write_line("odd(10): {is_odd(10)}");
// <<<
si
