use IO.Std.write_line;

entry() is
// >>>
    let is_even = (n, is_odd: int -> bool) =>
        if n == 0 then true else is_odd(n - 1) fi;

    let is_odd = n rec =>
        if n == 0 then false else is_even(n - 1, rec) fi;

    write_line("even(10): {is_even(10, is_odd)}");
    write_line("odd(10): {is_odd(10)}");
// <<<
si
