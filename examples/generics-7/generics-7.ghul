use IO.Std.write_line;

// >>>
trait Greetable is
    name: string;
si

// T must derive from Greetable, so .name is available on T
greet[T: Greetable](x: T) is
    write_line("hello, {x.name}");
si

class CAT(name: string): Greetable is
si
// <<<

entry() is
// >>>
    greet(CAT("whiskers"));
// <<<
si
