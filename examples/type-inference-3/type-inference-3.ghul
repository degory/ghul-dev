use IO.Std.write_line;

class Animal() is
si

class Cat(): Animal is
    purr() -> string => "purr";
si

// >>>
greet(a: Animal) is
    if isa Cat(a) then
        // a is a parameter of greet, narrowed to Cat
        // in this branch
        write_line(a.purr());
    fi
si
// <<<

entry() is
    greet(Cat());
si
