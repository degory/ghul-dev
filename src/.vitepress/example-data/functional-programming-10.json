  "name": "functional-programming-10",
  "code": "let add = (x, y) => x + y;\nwrite_line(\"add(5, 3): {add(5, 3)}\");\n\nlet classify = n =>\n    if n == 0 then\n        \"Zero\"\n    elif n % 2 == 0 /\\ n < 0 then\n        if n % 5 == 0 then\n            \"Negative even and multiple of 5\"\n        else\n            \"Negative even\"\n        fi\n    elif n % 2 != 0 /\\ n < 0 then\n        if n % 5 == 0 then\n            \"Negative odd and multiple of 5\"\n        else\n            \"Negative odd\"\n        fi\n    elif n % 2 == 0 then\n        if n % 5 == 0 then\n            \"Positive even and multiple of 5\"\n        else\n            \"Positive even\"\n        fi\n    else\n        if n % 5 == 0 then\n            \"Positive odd and multiple of 5\"\n        else\n            \"Positive odd\"\n        fi\n    fi;\n\nwrite_line(\"classifyNumber(-10): {classify(-10)}\");\nwrite_line(\"classifyNumber(-3): {classify(-3)}\");\nwrite_line(\"classifyNumber(0): {classify(0)}\");\nwrite_line(\"classifyNumber(4): {classify(4)}\");\nwrite_line(\"classifyNumber(25): {classify(25)}\");",
  "fullSource": "use IO.Std.write_line;\n\nentry() is\n    let add = (x, y) => x + y;\n    write_line(\"add(5, 3): {add(5, 3)}\");\n\n    let classify = n =>\n        if n == 0 then\n            \"Zero\"\n        elif n % 2 == 0 /\\ n < 0 then\n            if n % 5 == 0 then\n                \"Negative even and multiple of 5\"\n            else\n                \"Negative even\"\n            fi\n        elif n % 2 != 0 /\\ n < 0 then\n            if n % 5 == 0 then\n                \"Negative odd and multiple of 5\"\n            else\n                \"Negative odd\"\n            fi\n        elif n % 2 == 0 then\n            if n % 5 == 0 then\n                \"Positive even and multiple of 5\"\n            else\n                \"Positive even\"\n            fi\n        else\n            if n % 5 == 0 then\n                \"Positive odd and multiple of 5\"\n            else\n                \"Positive odd\"\n            fi\n        fi;\n\n    write_line(\"classifyNumber(-10): {classify(-10)}\");\n    write_line(\"classifyNumber(-3): {classify(-3)}\");\n    write_line(\"classifyNumber(0): {classify(0)}\");\n    write_line(\"classifyNumber(4): {classify(4)}\");\n    write_line(\"classifyNumber(25): {classify(25)}\");\nsi\n",
  "output": "add(5, 3): 8\nclassifyNumber(-10): Negative even and multiple of 5\nclassifyNumber(-3): Negative odd\nclassifyNumber(0): Zero\nclassifyNumber(4): Positive even\nclassifyNumber(25): Positive odd and multiple of 5\n",
