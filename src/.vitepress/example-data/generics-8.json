  "code": "// T: out marks Box[T] as covariant in T — a Box[CAT] is also a Box[Animal]\ntrait Box[T: out] is\n    contents() -> T;\nsi\nlet cats: Box[CAT] = CAT_BOX();\nlet animals: Box[Animal] = cats;   // covariance\n\nwrite_line(animals.contents().speak());",
  "fullSource": "use IO.Std.write_line;\n\n// T: out marks Box[T] as covariant in T — a Box[CAT] is also a Box[Animal]\ntrait Box[T: out] is\n    contents() -> T;\nsi\n\ntrait Animal is\n    speak() -> string;\nsi\n\nclass CAT: Animal is\n    init() is si\n    speak() -> string => \"meow\";\nsi\n\nclass CAT_BOX: Box[CAT] is\n    init() is si\n    contents() -> CAT => CAT();\nsi\n\nentry() is\n    let cats: Box[CAT] = CAT_BOX();\n    let animals: Box[Animal] = cats;   // covariance\n\n    write_line(animals.contents().speak());\nsi\n",
  "output": "meow\n",
