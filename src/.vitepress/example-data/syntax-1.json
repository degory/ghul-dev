{
  "name": "syntax-1",
  "code": "if x > y then\n    write_line(\"x > y\")\nelse\n    write_line(\"x <= y\")\nfi",
  "output": "x <= y\n",
  "diagnostics": [],
  "hovers": [
    { "startLine": 1, "startColumn": 4, "endLine": 1, "endColumn": 4, "text": "x: Ghul.int // local value" },
    { "startLine": 1, "startColumn": 8, "endLine": 1, "endColumn": 8, "text": "y: Ghul.int // local value" },
    { "startLine": 1, "startColumn": 6, "endLine": 1, "endColumn": 6, "text": "Ghul.<>(a: Ghul.int, b: Ghul.int) -> Ghul.int // innate function compare.order" },
    { "startLine": 2, "startColumn": 5, "endLine": 2, "endColumn": 14, "text": "IO.Std.write_line(value: Ghul.string) -> Ghul.void // class method" },
    { "startLine": 4, "startColumn": 5, "endLine": 4, "endColumn": 14, "text": "IO.Std.write_line(value: Ghul.string) -> Ghul.void // class method" }
  ]
}
