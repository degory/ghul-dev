  "code": "if isa Option.SOME(an_option) then\n    let value = an_option.value;\n    write_line(\"the option holds {value}\");\nfi",
  "fullSource": "use IO.Std.write_line;\n\nunion Option[T] is\n    SOME(value: T);\n    NONE;\nsi\n\nentry() is\n    let an_option: Option[int] = Option.SOME(42);\n    if isa Option.SOME(an_option) then\n        let value = an_option.value;\n        write_line(\"the option holds {value}\");\n    fi\nsi\n",
